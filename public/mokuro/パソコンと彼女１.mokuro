{"version":"0.2.4","title":"長門は俺短編集","title_uuid":"10c061ce-fdd6-4398-9063-5b669780a6fa","volume":"パソコンと彼女１","volume_uuid":"94cfcad8-1f96-4cf5-8181-b7a046cd613d","pages":[{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t001.jpg","blocks":[{"box":[527,16,568,244],"vertical":true,"font_size":21,"lines_coords":[[[546,16],[567,16],[567,244],[546,244]],[[527,17],[548,17],[548,197],[527,197]]],"lines":["新しい法律ができてから","川がきれいになった"]},{"box":[186,28,232,198],"vertical":true,"font_size":29,"lines_coords":[[[204,30],[232,30],[232,198],[204,198]],[[186,28],[216,28],[216,157],[186,157]]],"lines":["新しい法律になり","死刑が増えて"]},{"box":[18,20,39,190],"vertical":true,"font_size":16,"lines_coords":[[[20,20],[36,20],[36,187],[20,187]]],"lines":["犯罪者が激減した。"]},{"box":[13,380,201,789],"vertical":true,"font_size":79,"lines_coords":[[[20,397],[150,380],[201,761],[71,778]],[[13,412],[61,411],[68,756],[20,757]],[[45,429],[104,430],[101,789],[42,789]]],"lines":["そんなご時世に俺は国に返せない","国に返せなくなった。","ハチンコの借金が増えていると、"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t002.jpg","blocks":[{"box":[497,5,589,325],"vertical":true,"font_size":33,"lines_coords":[[[557,6],[589,6],[589,325],[557,325]],[[527,5],[560,5],[561,283],[528,283]],[[497,9],[530,9],[533,243],[500,243]]],"lines":["借金の返済ができないと、","認定され、法律により","パソコンになった。"]},{"box":[280,480,324,509],"vertical":false,"font_size":13,"lines_coords":[[[280,497],[319,480],[324,492],[285,509]]],"lines":["しかし"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t003.jpg","blocks":[{"box":[521,18,577,210],"vertical":true,"font_size":16,"lines_coords":[[[560,18],[576,18],[576,210],[560,210]],[[541,18],[557,18],[557,196],[541,196]],[[521,18],[538,18],[538,157],[521,157]]],"lines":["俺はトラックに入れられ","俺を「パソコン」として","買った家に向かう"]},{"box":[316,36,341,88],"vertical":true,"font_size":17,"lines_coords":[[[316,45],[333,45],[333,79],[316,79]]],"lines":["、、"]},{"box":[180,31,236,192],"vertical":true,"font_size":18,"lines_coords":[[[218,31],[235,31],[235,172],[218,172]],[[200,32],[217,32],[217,168],[200,168]],[[180,31],[199,31],[199,192],[180,192]]],"lines":["どこで俺の人生が","狂ったのだろうか","まあどうでもいいが"]},{"box":[89,377,146,539],"vertical":true,"font_size":19,"lines_coords":[[[129,378],[145,378],[145,539],[129,539]],[[110,378],[128,378],[128,539],[110,539]],[[89,377],[113,377],[113,421],[89,421]]],"lines":["次に目を開けたとき","俺は見知らぬ部屋に","いた。"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t004.jpg","blocks":[{"box":[517,15,571,292],"vertical":true,"font_size":17,"lines_coords":[[[555,17],[571,17],[571,229],[555,229]],[[536,17],[553,17],[553,142],[536,142]],[[517,15],[535,15],[536,292],[517,292]]],"lines":["俺はもう人間には戻れない","パソコンだから","俺をつかっている男性はそういった"]},{"box":[481,16,500,315],"vertical":true,"font_size":17,"lines_coords":[[[482,16],[500,16],[499,315],[481,315]]],"lines":["ジュースをいつもくれるのでいい人だ"]},{"box":[20,6,75,232],"vertical":true,"font_size":23,"lines_coords":[[[47,6],[75,6],[75,209],[48,209]],[[37,9],[59,9],[59,135],[37,135]],[[20,8],[39,8],[39,230],[20,230]]],"lines":["パソコンの画面は後ろに","ついていたので","依頼主の姿は見たことない。"]},{"box":[11,417,118,687],"vertical":true,"font_size":18,"lines_coords":[[[99,417],[117,417],[117,687],[99,687]],[[82,418],[100,418],[100,579],[82,579]],[[47,418],[65,418],[65,617],[47,617]],[[28,417],[46,417],[46,671],[28,671]],[[11,417],[27,417],[27,653],[11,653]]],"lines":["後ろをみてもいい権利はないので","俺は後ろをみれない","ただみたいとは思うので","まだ俺はパソコンではなく「俺」","としての意思はあるのだろう。"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t005.jpg","blocks":[{"box":[356,448,379,646],"vertical":true,"font_size":19,"lines_coords":[[[357,448],[376,448],[376,642],[357,642]]],"lines":["聞きたい事があった"]},{"box":[529,446,576,769],"vertical":true,"font_size":24,"lines_coords":[[[551,446],[575,446],[576,700],[553,700]],[[529,446],[553,446],[553,769],[529,769]]],"lines":["もしもこの後ろの男性に","俺が質問する権利があるのなら、"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t006.jpg","blocks":[{"box":[509,35,578,218],"vertical":true,"font_size":22,"lines_coords":[[[552,35],[576,35],[578,218],[553,218]],[[532,35],[553,35],[552,144],[530,144]],[[509,35],[530,35],[530,173],[509,173]]],"lines":["三日間動かないで","座っている","彼女の名前を"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t007.jpg","blocks":[{"box":[279,3,330,214],"vertical":true,"font_size":18,"lines_coords":[[[312,4],[330,4],[330,214],[312,214]],[[296,3],[314,3],[314,198],[296,198]],[[279,4],[296,4],[296,159],[280,159]]],"lines":["主人がいない時間の方が多く","俺はいつもなら「喋る権利」","がないので黙っている"]},{"box":[162,12,242,256],"vertical":true,"font_size":20,"lines_coords":[[[221,13],[242,13],[242,119],[221,119]],[[202,14],[221,14],[221,256],[202,256]],[[183,14],[202,14],[202,139],[183,139]],[[164,12],[185,12],[184,153],[162,153]]],"lines":["あ．．．あの！","貴女：生きていますよね？","おなかの穴．．．","大丈夫ですか？"]},{"box":[496,413,559,610],"vertical":true,"font_size":19,"lines_coords":[[[539,413],[557,413],[559,557],[540,557]],[[517,414],[536,414],[536,610],[517,610]],[[496,413],[515,413],[515,557],[496,557]]],"lines":["いってしまった！","「喋る権利」がないのに","いってしまった！"]},{"box":[457,413,476,736],"vertical":true,"font_size":19,"lines_coords":[[[457,413],[476,413],[476,736],[457,736]]],"lines":["俺はパソコンなのに喋ってしまった！！"]},{"box":[327,365,373,581],"vertical":true,"font_size":46,"lines_coords":[[[327,365],[373,365],[373,581],[327,581]]],"lines":["貴女じゃない"]},{"box":[0,346,100,605],"vertical":true,"font_size":100,"lines_coords":[[[0,347],[99,346],[100,604],[0,605]]],"lines":["私は．．．私は結婚指輪"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t008.jpg","blocks":[{"box":[291,7,336,226],"vertical":true,"font_size":22,"lines_coords":[[[313,11],[336,11],[336,226],[313,226]],[[291,14],[313,14],[313,146],[291,146]]],"lines":["俺の名前は：：あれ．．．","なんだっけ．．．"]},{"box":[254,5,269,142],"vertical":true,"font_size":13,"lines_coords":[[[254,5],[267,5],[268,142],[255,142]]],"lines":["貴方はパソコンでしょ？"]},{"box":[555,361,592,572],"vertical":true,"font_size":18,"lines_coords":[[[569,361],[590,361],[592,518],[571,518]],[[555,363],[571,363],[572,572],[556,572]]],"lines":["私は前自分が人間で","あったかも忘れてしまったの"]},{"box":[380,395,415,583],"vertical":true,"font_size":18,"lines_coords":[[[396,395],[415,395],[415,583],[396,583]],[[381,395],[397,395],[396,549],[380,549]]],"lines":["喋る権利なんてないのに","喋っていいのかな．．．"]},{"box":[233,364,308,564],"vertical":true,"font_size":18,"lines_coords":[[[290,364],[307,364],[307,495],[290,495]],[[271,364],[290,364],[290,508],[271,508]],[[252,364],[271,364],[271,564],[252,564]],[[234,365],[250,365],[250,507],[234,507]]],"lines":["僕と結婚指輪は","それをきっかけに","主人がいなくなったあと","話すようになった"]},{"box":[53,621,89,790],"vertical":true,"font_size":18,"lines_coords":[[[71,621],[89,621],[89,771],[71,771]],[[53,621],[71,621],[71,790],[53,790]]],"lines":["俺はいつのまにか","指輪に恋をしていた"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t009.jpg","blocks":[{"box":[547,12,565,151],"vertical":true,"font_size":16,"lines_coords":[[[547,12],[563,12],[563,150],[547,150]]],"lines":["ただ幾月たっても"]},{"box":[299,23,317,151],"vertical":true,"font_size":16,"lines_coords":[[[300,25],[316,25],[316,150],[300,150]]],"lines":["いくら話しても"]},{"box":[85,17,154,738],"vertical":true,"font_size":69,"lines_coords":[[[85,17],[154,17],[154,738],[85,738]]],"lines":["彼女は後ろを振り向かなかった。"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t010.jpg","blocks":[{"box":[558,10,589,185],"vertical":true,"font_size":15,"lines_coords":[[[575,11],[589,11],[589,122],[575,122]],[[558,10],[574,10],[574,185],[558,185]]],"lines":["俺は今の生活に","不満があるわけではない"]},{"box":[7,195,40,323],"vertical":true,"font_size":18,"lines_coords":[[[21,195],[40,195],[40,292],[21,292]],[[7,195],[23,195],[23,323],[7,323]]],"lines":["ただいつしか","彼女と話す内容は"]},{"box":[521,468,570,645],"vertical":true,"font_size":16,"lines_coords":[[[554,469],[570,469],[568,645],[553,645]],[[536,468],[552,468],[552,564],[536,564]],[[521,470],[538,470],[538,545],[521,545]]],"lines":["「この家から脱出しよう」","というものに","なっていた"]},{"box":[71,531,103,594],"vertical":true,"font_size":16,"lines_coords":[[[87,531],[103,531],[103,594],[87,594]],[[72,531],[89,531],[87,594],[71,594]]],"lines":["もちろん","一緒にだ"]}]},{"version":"0.2.4","img_width":600,"img_height":800,"img_path":"パソコンと彼女１/t011.jpg","blocks":[{"box":[571,5,588,85],"vertical":true,"font_size":14,"lines_coords":[[[573,5],[587,5],[585,85],[571,85]]],"lines":["そういえば"]},{"box":[158,0,242,117],"vertical":true,"font_size":84,"lines_coords":[[[158,0],[242,0],[242,117],[158,117]]],"lines":["指輪の私に歩く権利はないけれど"]},{"box":[0,122,39,266],"vertical":true,"font_size":37,"lines_coords":[[[0,123],[35,122],[39,265],[0,266]]],"lines":["歩けるよ"]},{"box":[265,172,311,353],"vertical":true,"font_size":24,"lines_coords":[[[286,173],[311,173],[311,268],[286,268]],[[265,172],[289,172],[289,353],[265,353]]],"lines":["あなたは","歩けますか．．．？"]},{"box":[524,461,586,660],"vertical":true,"font_size":62,"lines_coords":[[[524,461],[586,461],[586,660],[524,660]]],"lines":["このとき俺はこの家にきて"]},{"box":[405,475,460,585],"vertical":true,"font_size":14,"lines_coords":[[[445,475],[460,475],[460,560],[445,560]],[[433,477],[444,477],[444,585],[433,585]],[[417,475],[433,475],[433,572],[417,572]],[[405,476],[418,476],[418,532],[405,532]]],"lines":["よし．．．じゃあ","この部屋を出よう","主人は車の音が","したから"]},{"box":[180,511,207,593],"vertical":true,"font_size":14,"lines_coords":[[[192,511],[206,511],[206,579],[192,579]],[[180,511],[193,511],[193,593],[180,593]]],"lines":["しばらくは","こないと思う"]},{"box":[0,457,103,671],"vertical":true,"font_size":20,"lines_coords":[[[82,458],[100,458],[102,646],[83,646]],[[59,459],[80,458],[83,580],[62,581]],[[40,458],[61,458],[61,671],[40,671]],[[20,459],[39,459],[39,652],[20,652]],[[0,457],[17,457],[19,560],[0,560]]],"lines":["初めて、二つの意味で","立ち上がった。","無謀だとはわかっていた。","ただ彼女の笑った顔を","見たかった。"]}]}],"chars":879}