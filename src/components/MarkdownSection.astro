---
import { type Word } from "@/locale";
import JustMarkdown from "./JustMarkdown.astro";

interface Props {
  heading: string;
  text: Word | undefined;
}

const { heading, text } = Astro.props;
---

{
  text && (
    <section class="[&_img]:inline [&_img]:max-w-105 [&_ol]:list-inside [&_ol]:list-decimal">
      <h2 class="text-lg font-semibold">{heading}</h2>
      <JustMarkdown text={text} />
    </section>
  )
}
