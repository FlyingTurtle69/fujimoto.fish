---
import type { Manga } from "@/content/manga";
import { displayWord, type Locale } from "@/locale";

interface Props {
  manga: Manga;
  className?: string;
}

const locale = Astro.params.locale as Locale;
const { manga, className = "" } = Astro.props;
const { published } = manga;

const TEXT = {
  published: { en: "Published", jp: "公開済み" },
  "self-published": { en: "Self-Published", jp: "自主制作" },
  unpublished: { en: "Not Published", jp: "未公開" },
} as const;

const CLASS = {
  published: "badge-success",
  "self-published": "badge-warning",
  unpublished: "badge-error",
} as const;
---

<div class={`badge ${CLASS[published]} ${className}`}>{displayWord(TEXT[published], locale)}</div>
