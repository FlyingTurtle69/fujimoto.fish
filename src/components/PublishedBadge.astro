---
import type { Manga } from "@/content/manga";

interface Props {
  manga: Manga;
}

const { manga } = Astro.props;
const { published } = manga;

const TEXT = {
  published: "Published",
  "self-published": "Self-Published",
  unpublished: "Not Published",
} as const;

const CLASS = {
  published: "badge-success",
  "self-published": "badge-warning",
  unpublished: "badge-error",
} as const;
---

<div class={`badge ${CLASS[published]}`}>{TEXT[published]}</div>
