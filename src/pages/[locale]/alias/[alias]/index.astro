---
import Layout from "@/layouts/Layout.astro";
import { ALIASES } from "@/content/aliases";
import { getStaticPaths as getLocalPaths } from "@/pages/[locale]/index.astro";
import { objectKeys, objectMap } from "@/utils/object";
import { displayWord } from "@/locale";
import { MANGA } from "@/content/manga";
import MangaList from "@/components/MangaList.astro";
import MarkdownSection from "@/components/MarkdownSection.astro";
import ExternalLink from "@/components/ExternalLink.astro";
import Markdown from "astro-remote/lib/Markdown.astro";

export function getStaticPaths() {
  return getLocalPaths().flatMap(({ params: { locale } }) =>
    objectMap(ALIASES, ([alias]) => ({ params: { locale, alias } })),
  );
}

const { locale, alias } = Astro.params;
const { name, description, fujimotoProof, links } = ALIASES[alias];

const manga = objectKeys(MANGA).filter((m) => MANGA[m].alias === alias);
---

<Layout>
  <h1 class="text-secondary text-center text-3xl font-bold">{displayWord(name, locale)}</h1>
  {
    description && (
      <Markdown content={displayWord(description, locale)} components={{ a: ExternalLink }} />
    )
  }
  {
    links && links.length > 0 && (
      <section>
        <h2 class="text-lg font-semibold">Accounts and Websites</h2>
        <ul class="list-inside list-disc">
          {links.map((l) => (
            <li>
              {l.link ? <ExternalLink href={l.link}>{l.name}</ExternalLink> : l.name}{" "}
              {l.explanation && (
                <>
                  ({l.explanation}
                  {l.explanationLink && (
                    <>
                      Explained <ExternalLink href={l.explanationLink}>here</ExternalLink>
                    </>
                  )}
                  {")"}
                </>
              )}
            </li>
          ))}
        </ul>
      </section>
    )
  }
  <MarkdownSection heading="Evidence for being Fujimoto" text={fujimotoProof} locale={locale} />
  <h2 class="mb-0 text-lg font-semibold">Manga</h2>
  <MangaList manga={manga} locale={locale} />
</Layout>
