{
  "name": "fujimoto-fish",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-06-30",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": ["/"],
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "fujimoto.fish",
      "custom_domain": true
    }
  ]
}
